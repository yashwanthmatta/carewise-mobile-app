{
  "name": "carewise-mobile-app",
  "version": "0.1.0",
  "private": true,
  "main": "node_modules/expo/AppEntry.js",
  "scripts": {
    "start": "expo start",
    "phone": "expo start --go --tunnel --clear --port 8082",
    "android": "expo start --android",
    "ios": "expo start --ios",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "ci:check": "node scripts/ci_check.js",
    "release:check": "node scripts/mobile_release_check.js",
    "store:check": "node scripts/store_submission_check.js",
    "review:check": "node scripts/app_review_check.js",
    "backend:check": "node scripts/backend_connectivity_check.js",
    "auth:smoke": "node scripts/auth_smoke_check.js",
    "report:smoke": "node scripts/report_smoke_check.js",
    "build:preflight": "node scripts/eas_build_preflight.js",
    "eas:login": "eas login",
    "build:android:preview": "eas build --platform android --profile preview",
    "build:ios:preview": "eas build --platform ios --profile preview"
  },
  "dependencies": {
    "@expo/vector-icons": "^15.0.2",
    "@react-native-async-storage/async-storage": "2.2.0",
    "expo": "^56.0.12",
    "expo-asset": "~56.0.17",
    "expo-constants": "~56.0.20",
    "expo-document-picker": "~56.0.4",
    "expo-secure-store": "~56.0.4",
    "expo-status-bar": "~56.0.4",
    "react": "19.2.3",
    "react-native": "0.85.3"
  },
  "devDependencies": {
    "@expo/ngrok": "^4.1.3",
    "@types/react": "^19.2.17",
    "eas-cli": "^20.5.1",
    "typescript": "~6.0.3"
  }
}
